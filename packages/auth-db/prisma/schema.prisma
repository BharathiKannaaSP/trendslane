generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("AUTH_DATABASE_URL")
}
enum SystemRole {
  ADMIN
  USER
}

enum OrganizationRole {
  ORG_ADMIN
  ORG_MEMBER
}

enum OrganizationStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
  NEEDS_ADDITIONAL_INFO
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  WAITING_APPROVAL
  APPROVED
  REJECTED
}

enum AccountType {
  ADMIN
  ORG_ADMIN
  ORG_MEMBER
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdminRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id String @id @default(cuid())

  // External Auth Identity
  clerkUserId String @unique

  email    String @unique
  username String @unique

  firstName String
  lastName  String

  imageUrl String?

  // RBAC
  systemRole SystemRole @default(USER)

  // Onboarding
  onboardingStatus OnboardingStatus @default(PENDING)
  selectedAccountType AccountType?
  onboardingCompletedAt DateTime?
  onboardingRejectionReason String?

  // Country
  countryName String?
  countryCode String?

  // Status
  isActive Boolean @default(true)
  lastLoginAt DateTime?
  clerkSyncedAt DateTime?

  createdByClerkUserId String?
  createdBy  User? @relation("CreatedByUser", fields: [createdByClerkUserId], references: [clerkUserId])
  createdAt DateTime @default(now())
  createdUsers User[] @relation("CreatedByUser")

  deletedByClerkUserId String?
  deletedBy User? @relation("DeletedByUser", fields: [deletedByClerkUserId], references: [clerkUserId])
  deletedAt DateTime?
  deletedUsers User[] @relation("DeletedByUser")

  updatedByClerkUserId String?
  updatedBy User? @relation("UpdatedByUser", fields: [updatedByClerkUserId], references: [clerkUserId])
  updatedAt DateTime @updatedAt
  updatedUsers User[] @relation("UpdatedByUser")

  // Country Audit Relations
  createdCountries Country[] @relation("CreatedCountries")
  updatedCountries Country[] @relation("UpdatedCountries")
  deletedCountries Country[] @relation("DeletedCountries")

  // Organization Audit Relations
  createdOrganizations Organization[] @relation("CreatedOrganizations")
  approvedOrganizations Organization[] @relation("ApprovedOrganizations")

  // Memberships
  memberships OrganizationMember[]

  // Admin Requests
  adminRequests AdminRequest[]

  // Invitation Audit Relations
  sentInvitations OrganizationInvitation[] @relation("SentInvitations")
  acceptedInvitations OrganizationInvitation[] @relation("AcceptedInvitations")

  @@index([clerkUserId])
  @@index([email])
  @@index([username])
  @@index([systemRole])
  @@index([onboardingStatus])
  @@index([countryCode])
  @@index([isActive])
}

model Country {
  // Core
  id String @id @default(cuid())
  code String @unique
  name String @unique
  slug String @unique
  timezone String
  defaultLanguage String @default("en")
  supportedLanguages String[]
  currencyCode String
  currencySymbol String
  currencyName String
  phoneCode String
  notes String?
  isActive Boolean @default(true)

  // Created Audit
  createdByClerkUserId String
  createdBy User @relation("CreatedCountries", fields: [createdByClerkUserId], references: [clerkUserId])
  createdAt DateTime @default(now())

  // Updated Audit
  updatedByClerkUserId String?
  updatedBy User? @relation("UpdatedCountries", fields: [updatedByClerkUserId], references: [clerkUserId])
  updatedAt DateTime @updatedAt

  // Deleted Audit
  deletedByClerkUserId String?
  deletedBy User? @relation("DeletedCountries", fields: [deletedByClerkUserId], references: [clerkUserId])
  deletedAt DateTime?

  // Organizations
  organizations Organization[]

  @@index([isActive, name])
}

model Organization {
  id String @id @default(cuid())

  // Clerk Organization
  clerkOrganizationId String? @unique

  // Core
  name String

  slug String

  description String?

  logoUrl String?

  status OrganizationStatus @default(PENDING)

  isActive Boolean @default(true)

  rejectionReason String?

  suspendedReason String?

  // Country
  countryId String

  country Country @relation(fields: [countryId], references: [id])

  // Created Audit
  createdByClerkUserId String

  createdBy User @relation("CreatedOrganizations", fields: [createdByClerkUserId],references: [clerkUserId])

  // Approval Audit
  approvedByClerkUserId String?

  approvedBy User? @relation("ApprovedOrganizations",fields: [approvedByClerkUserId],references: [clerkUserId])

  approvedAt DateTime?

  // Soft Delete
  deletedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // Relations
  members OrganizationMember[]

  invitations OrganizationInvitation[]

  @@unique([countryId, slug])

  @@index([countryId])
  @@index([status])
  @@index([isActive])
  @@index([createdByClerkUserId])
  @@index([approvedByClerkUserId])
  @@index([deletedAt])
}

model OrganizationMember {
  id String @id @default(cuid())

  // Organization
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // User
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Role
  role OrganizationRole

  // Approval Workflow
  status MembershipStatus @default(PENDING)

  rejectionReason String?
  approvedByClerkUserId String?
  approvedAt DateTime?

  // Status
  isActive Boolean @default(true)
  joinedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId])

  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@index([status])
  @@index([isActive])
}

model OrganizationInvitation {
  id String @id @default(cuid())

  email String

  // Organization
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Role
  role           OrganizationRole

  // Invited By Audit
  invitedByClerkUserId String
  invitedBy            User   @relation("SentInvitations", fields: [invitedByClerkUserId], references: [clerkUserId])

  // Accepted By Audit
  acceptedByClerkUserId String?

  acceptedBy User? @relation("AcceptedInvitations", fields: [acceptedByClerkUserId], references: [clerkUserId])

  // Invitation
  token String @unique
  status InvitationStatus @default(PENDING)
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([organizationId])
  @@index([status])
  @@index([email, status])
}


model AdminRequest {
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id],onDelete: Cascade)
  status AdminRequestStatus @default(PENDING)
  reason String?
  reviewedByClerkUserId String?
  reviewedAt DateTime?
  rejectionReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId])
  @@index([status])
}
