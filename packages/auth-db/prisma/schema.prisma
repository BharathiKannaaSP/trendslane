// GENERATOR & DATASOURCE
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("AUTH_DATABASE_URL")
}

// RBAC ENUMS
enum SystemRole {
  ADMIN
  USER
}

enum AccountType {
  ADMIN
  ORG_ADMIN
  ORG_MEMBER
}

enum OrganizationRole {
  ORG_ADMIN
  ORG_MEMBER
}


// ONBOARDING ENUMS
enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  WAITING_APPROVAL
  APPROVED
  REJECTED
}

enum OnboardingStep {
  BASIC_INFORMATION
  ADDITIONAL_DETAILS
  ROLE_REQUIREMENTS
  COMPLETED
}

enum OnboardingPath {
  JOIN_ORGANIZATION
  CREATE_ORGANIZATION
  BECOME_ADMIN
}

// ORGANIZATION ENUMS
enum OrganizationStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
  NEEDS_ADDITIONAL_INFO
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

// ADMIN REQUEST ENUMS
enum AdminRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// USER PREFERENCES
enum ThemeMode {
  LIGHT
  DARK
  SYSTEM
}

enum ThemeRadius {
  SM
  MD
  LG
}

enum ThemeScale {
  COMPACT
  COMFORTABLE
  SPACIOUS
}


model User {
  // IDENTITY
  id String @id @default(cuid())
  clerkUserId String @unique
  email String @unique
  username String @unique
  firstName String
  lastName String
  imageUrl String?

  // ACCESS CONTROL
  systemRole SystemRole @default(USER)

  // ONBOARDING
  onboardingStatus OnboardingStatus @default(PENDING)
  onboardingStep OnboardingStep @default(BASIC_INFORMATION)
  onboardingStepNo Int @default(1)
  onboardingPath OnboardingPath?
  selectedAccountType AccountType?
  onboardingStartedAt DateTime?
  onboardingCompletedAt DateTime?
  onboardingRejectionReason String?

  // BIO COUNTRY
  countryName String?
  countryCode String?

  // PROFILE
  phoneNumber String?
  address String? @db.Text
  bio String? @db.Text
  timezone String?
  language String?
  referralCode String?

  // Preferences
  preferences UserPreferences?

  // ACCOUNT STATUS
  isActive Boolean @default(true)
  lastLoginAt DateTime?
  clerkSyncedAt DateTime?

  // AUDIT
  createdByClerkUserId String?
  createdBy User? @relation("CreatedByUser", fields: [createdByClerkUserId], references: [clerkUserId])
  createdUsers User[] @relation("CreatedByUser")
  createdAt DateTime @default(now())

  updatedByClerkUserId String?
  updatedBy User? @relation("UpdatedByUser", fields: [updatedByClerkUserId], references: [clerkUserId])
  updatedUsers User[] @relation("UpdatedByUser")
  updatedAt DateTime @updatedAt

  deletedByClerkUserId String?
  deletedBy User? @relation("DeletedByUser", fields: [deletedByClerkUserId], references: [clerkUserId])
  deletedUsers User[] @relation("DeletedByUser")
  deletedAt DateTime?

  // RELATIONS
  createdCountries Country[] @relation("CreatedCountries")
  updatedCountries Country[] @relation("UpdatedCountries")
  deletedCountries Country[] @relation("DeletedCountries")

  createdOrganizations Organization[] @relation("CreatedOrganizations")
  approvedOrganizations Organization[] @relation("ApprovedOrganizations")
  updatedOrganizations Organization[] @relation("UpdatedOrganizations")
  deletedOrganizations Organization[] @relation("DeletedOrganizations")

  memberships OrganizationMember[]
  approvedMemberships OrganizationMember[] @relation("ApprovedMemberships")

  sentInvitations OrganizationInvitation[] @relation("SentInvitations")
  acceptedInvitations OrganizationInvitation[] @relation("AcceptedInvitations")

  adminRequests AdminRequest[]
  reviewedAdminRequests AdminRequest[] @relation("ReviewedAdminRequests")

  // INDEXES
  @@index([clerkUserId])
  @@index([email])
  @@index([username])
  @@index([systemRole])
  @@index([onboardingStatus])
  @@index([onboardingStep])
  @@index([countryCode])
  @@index([isActive])
}

model UserPreferences {
  id String @id @default(cuid())

  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // THEME
  themeMode ThemeMode @default(SYSTEM)

  themeAccent String @default("default")
  themePreset String @default("default")
  themeSidebar String @default("default")

  themeRadius ThemeRadius @default(MD)
  themeScale ThemeScale @default(COMFORTABLE)

  themeAccentCustomized Boolean @default(false)
  themeVersion Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Organization {
  // IDENTITY
  id String @id @default(cuid())
  clerkOrganizationId String? @unique
  name String
  slug String
  description String?
  logoUrl String?

  // STATUS
  status OrganizationStatus @default(PENDING)
  isActive Boolean @default(true)
  rejectionReason String?
  suspendedReason String?

  // COUNTRY
  countryId String
  country Country @relation(fields: [countryId], references: [id])

  // CREATED BY
  createdByClerkUserId String
  createdBy User @relation("CreatedOrganizations", fields: [createdByClerkUserId], references: [clerkUserId])

  // APPROVAL
  approvedByClerkUserId String?
  approvedBy User? @relation("ApprovedOrganizations", fields: [approvedByClerkUserId], references: [clerkUserId])
  approvedAt DateTime?

  // UPDATED BY
  updatedByClerkUserId String?
  updatedBy User? @relation("UpdatedOrganizations", fields: [updatedByClerkUserId], references: [clerkUserId])

  // DELETED BY
  deletedByClerkUserId String?
  deletedBy User? @relation("DeletedOrganizations", fields: [deletedByClerkUserId], references: [clerkUserId])
  deletedAt DateTime?

  // TIMESTAMPS
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RELATIONS
  members OrganizationMember[]
  invitations OrganizationInvitation[]

  // CONSTRAINTS
  @@unique([countryId, slug])

  @@index([countryId])
  @@index([status])
  @@index([isActive])
  @@index([createdByClerkUserId])
  @@index([approvedByClerkUserId])
  @@index([updatedByClerkUserId])
  @@index([deletedByClerkUserId])
  @@index([deletedAt])
}

model OrganizationMember {
  id String @id @default(cuid())

  // Organization
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // User
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Role
  role OrganizationRole

  // Approval Workflow
  status MembershipStatus @default(PENDING)

  rejectionReason String?

approvedByClerkUserId String?
approvedBy User? @relation("ApprovedMemberships", fields: [approvedByClerkUserId], references: [clerkUserId])
approvedAt DateTime?

  // Status
  isActive Boolean @default(true)
  joinedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId])

  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@index([status])
  @@index([isActive])
}

model OrganizationInvitation {
  id String @id @default(cuid())
  email String

  // Organization
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Role
  role           OrganizationRole

  // Invited By Audit
  invitedByClerkUserId String
  invitedBy            User   @relation("SentInvitations", fields: [invitedByClerkUserId], references: [clerkUserId])

  // Accepted By Audit
  acceptedByClerkUserId String?
  acceptedBy User? @relation("AcceptedInvitations", fields: [acceptedByClerkUserId], references: [clerkUserId])

  // Invitation
  token String @unique
  status InvitationStatus @default(PENDING)
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([organizationId])
  @@index([status])
  @@index([email, status])
}


model AdminRequest {
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id],onDelete: Cascade)
  status AdminRequestStatus @default(PENDING)
  reason String?
  reviewedByClerkUserId String?
  reviewedBy User? @relation("ReviewedAdminRequests", fields: [reviewedByClerkUserId], references: [clerkUserId])
  reviewedAt DateTime?
  rejectionReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId])
  @@index([status])
}


model Country {
  // IDENTITY
  id String @id @default(cuid())
  code String @unique
  name String @unique
  slug String @unique

  // LOCALIZATION
  timezone String
  defaultLanguage String @default("en")
  supportedLanguages String[]

  // CURRENCY
  currencyCode String
  currencySymbol String
  currencyName String

  // CONTACT
  phoneCode String

  // STATUS
  notes String?
  isActive Boolean @default(true)

  // Created Audit
  createdByClerkUserId String
  createdBy User @relation("CreatedCountries", fields: [createdByClerkUserId], references: [clerkUserId])
  createdAt DateTime @default(now())

  // Updated Audit
  updatedByClerkUserId String?
  updatedBy User? @relation("UpdatedCountries", fields: [updatedByClerkUserId], references: [clerkUserId])
  updatedAt DateTime @updatedAt

  // Deleted Audit
  deletedByClerkUserId String?
  deletedBy User? @relation("DeletedCountries", fields: [deletedByClerkUserId], references: [clerkUserId])
  deletedAt DateTime?

  // Organizations
  organizations Organization[]

  @@index([isActive, name])
}
