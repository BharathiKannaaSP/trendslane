{
  "$schema": "https://v2-9-16.turborepo.dev/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "CLERK_WEBHOOK_SIGNING_SECRET",
    "AUTH_PORT",
    "PORT",
    "ADMIN_USER_IDS",
    "REDIS_URL",
    "ANALYZE",
    "CLERK_SECRET_KEY",
    "CONVEX_URL",
    "CORS_ORIGIN_ADMIN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:deploy": {
      "cache": false
    }
  }
}
